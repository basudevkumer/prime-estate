backend/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
frontend/coverage/

# next.js (Root এবং frontend ফোল্ডার দুটোর জন্যই ফিক্সড)
